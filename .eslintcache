t":0,"fixableWarningCount":0},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},"/home/sebastian/Proyectos/Personal Mark/frontend/src/serviceWorker.js",[],["96","97"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/index.tsx",[],["98","99"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/App.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Typography.tsx",["100"],"import React from 'react';\nimport ThemeContext from '../contexts/ThemeContext';\n\nimport './Typography.css'\n\ninterface TypographyProps extends\n    React.ComponentProps<React.FC>\n    , React.HTMLAttributes<HTMLElement> {\n  component?: string;\n  special?: boolean;\n}\n\nfunction Typography(props: TypographyProps) {\n  const { children, component='span', special, ...opts } = props;\n\n  // const theme = React.useContext(ThemeContext);\n  const className = opts.className ? opts.className : '';\n  opts.className = special ? `${className} typography-special` : className;\n\n  return React.createElement(component, opts, children);\n}\n\nexport default Typography;\n","/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Carousel.tsx",[],["101","102"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Content.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/NavBar.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Archive.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Footer.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Post.tsx",["103","104","105"],"import React from 'react';\nimport Typography from './Typography';\nimport Link from './button/Link';\n\nimport './Post.css'\nimport Icon from './Icon';\nimport Row from './layout/Row';\n\nfunction Post(props: React.ComponentProps<React.FC>) {\n  const { children } = props;\n\n  return (\n    <article className=\"Post\">\n      <hgroup className=\"Post__header\">\n        <h2 className=\"Post__headline1\">Lorem ipsum</h2>\n        <h3 className=\"Post__headline2\">Dolor sit amet</h3>\n\n        <Link href=\"#\">\n          <Typography className=\"Post__caption\">\n            tags (1)\n          </Typography>\n        </Link>\n      </hgroup>\n\n      <p className=\"Post__body\">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nam felis lorem, pulvinar ac neque in, tincidunt feugiat libero. Sed laoreet at mi at convallis. Cras in tincidunt tortor, nec volutpat est. Sed pretium sodales nisl, ac hendrerit libero luctus sit amet. Nam rutrum tempus justo, ac semper sapien.</p> \n\n      <p className=\"Post__body\">Suspendisse imperdiet enim nulla, nec euismod ipsum scelerisque a. Aliquam fermentum accumsan eros. Cras nibh massa, faucibus sed orci ac, faucibus faucibus tortor. Vivamus placerat blandit luctus.</p> \n      \n      <p className=\"Post__body\">Maecenas sit amet arcu gravida, volutpat justo nec, ultricies velit. Aliquam erat volutpat. Integer felis nunc, luctus id pretium nec, lobortis id tortor. Phasellus pretium non libero et dictum.</p>\n\n      <p className=\"Post__body\">In hac habitasse platea dictumst. In mollis risus ex, vitae imperdiet nibh posuere at. Mauris porta nisl leo, semper sodales augue ullamcorper non. Donec congue, ligula sed fringilla molestie, enim quam sagittis leo, ut vestibulum justo quam et purus.</p>\n      \n      <p className=\"Post__body\">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vel lacus lectus. Sed ac eleifend purus. Duis dapibus eros finibus, tempor augue vel, pellentesque erat. Aliquam sed elit ut tortor lobortis molestie. Morbi at magna ex.</p>\n\n      <p className=\"Post__body\">Suspendisse commodo urna ante, quis pretium diam congue sit amet. Vestibulum vehicula tempus molestie. Donec commodo diam quis sem condimentum, vitae volutpat ante tincidunt. Donec interdum elit vel orci rhoncus viverra.</p> \n      \n      <p className=\"Post__body\">Donec quis nibh eget enim euismod luctus. Donec at tortor ipsum. In dignissim ex sed consequat pretium. Aenean vitae nulla urna. Etiam aliquam varius ante a egestas. Proin dictum et urna ut malesuada. Nam tristique nunc at quam tempor pulvinar.</p> \n      \n      <p className=\"Post__body\">Suspendisse rhoncus non justo vel volutpat. Quisque at ultrices lacus, eget posuere purus. Donec ultrices diam justo, sed cursus dolor vestibulum eu.</p>\n\n      <footer className=\"Post__footer\">\n        {/* <Row>\n          <Icon icon=\"notifications\" />\n          <Icon icon=\"notifications\" />\n        </Row> */}\n      </footer>\n    </article>\n  );\n}\n\nexport default Post;\n","/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Search.tsx",["106"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Select.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Icon.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/button/ButtonIcon.tsx",["107"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/button/Link.tsx",[],["108","109"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/layout/Row.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/layout/Column.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/layout/Card.tsx",["110","111","112"],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/layout/Space.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/button/ButtonLink.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/pages/Blog.tsx",[],"/home/sebastian/Proyectos/Personal Mark/frontend/src/components/Separator.tsx",[],{"ruleId":"113","replacedBy":"114"},{"ruleId":"115","replacedBy":"116"},{"ruleId":"113","